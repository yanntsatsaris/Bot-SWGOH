# ==============================================================================
# Fichier de configuration - COPIER en .env et NE JAMAIS committer .env
# ==============================================================================

# Token du bot Discord
DISCORD_TOKEN=your_discord_bot_token_here

# ID du serveur Discord (Guild ID)
DISCORD_GUILD_ID=

# URL de l'API SWGOH (swgoh.gg API publique)
SWGOH_API_URL=https://swgoh.gg/api

# Comlink local (Docker)
COMLINK_URL=http://localhost:3200

# Asset Extractor local (Docker)

# Chemin vers la base de données SQLite
DATABASE_PATH=database/swgoh.db
